#!/usr/bin/env bash
set -euo pipefail

safe_pgrep() { pgrep "$@" 2>/dev/null || true; }

get_parent() {
    xwininfo -id "$1" -tree 2>/dev/null | grep -oP 'Parent window id: \K0x[0-9a-f]+'
}

wid=$(xprop -root _NET_ACTIVE_WINDOW 2>/dev/null | grep -oP '0x[0-9a-fA-F]+')
[ -z "$wid" ] && { echo "$HOME"; exit 0; }

# Walk up to managed window (has WM_STATE)
for _ in {1..20}; do
    xprop -id "$wid" WM_STATE 2>/dev/null | grep -q 'WM_STATE' && break
    parent=$(get_parent "$wid")
    [ -z "$parent" ] && { echo "$HOME"; exit 0; }
    wid=$parent
done

# Emacs
wm_class=$(xprop -id "$wid" WM_CLASS 2>/dev/null)
if echo "$wm_class" | grep -qi '"Emacs"'; then
    cwd=$(emacsclient --eval '(expand-file-name default-directory)' 2>/dev/null | tr -d '"' | head -1)
    [ -n "$cwd" ] && [ -d "$cwd" ] && { echo "$cwd"; exit 0; }
    echo "$HOME"; exit 0
fi

# Get PID from _NET_WM_PID
pid=$(xprop -id "$wid" _NET_WM_PID 2>/dev/null | grep -oP '\d+')
[ -z "$pid" ] && { echo "$HOME"; exit 0; }

# Walk down to deepest child
while true; do
    child=$(safe_pgrep -P "$pid" | head -1)
    [ -z "$child" ] && break
    pid=$child
done

cwd=$(readlink "/proc/$pid/cwd" 2>/dev/null)
[ -n "$cwd" ] && [ -d "$cwd" ] || { echo "$HOME"; exit 0; }
echo "$cwd"
