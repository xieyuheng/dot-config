[user]
        email = xyheme@gmail.com
        name = Xie Yuheng
[core]
        editor = emacsclient -c
        pager = diff-so-fancy | less --quit-if-one-screen --mouse --raw-control-chars
[pull]
        rebase = true
[push]
        autoSetupRemote = true
[alias]
        log-line = log --graph --all --topo-order --date=format-local:'%Y-%m-%d %H:%M:%S' --pretty=format:'%C(cyan)%h%Creset %C(black bold)%ad%Creset%C(auto)%d %s'